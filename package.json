{
  "name": "idea2real",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "agentic": "pnpm --dir tools/agentic-control start",
    "a": "pnpm --dir tools/agentic-control start",
    "a:continue": "pnpm --dir tools/agentic-control start continue",
    "a:start": "pnpm --dir tools/agentic-control start session start",
    "a:resume": "pnpm --dir tools/agentic-control start session resume",
    "a:solo-start": "pnpm --dir tools/agentic-control start solo start",
    "a:solo-resume": "pnpm --dir tools/agentic-control start solo resume",
    "a:solo-add": "pnpm --dir tools/agentic-control start solo add-issues",
    "a:solo-checkpoint": "pnpm --dir tools/agentic-control start solo checkpoint",
    "a:solo-finalize": "pnpm --dir tools/agentic-control start solo finalize",
    "a:done": "pnpm --dir tools/agentic-control start slice finalize",
    "a:loop": "pnpm --dir tools/agentic-control start pr loop",
    "a:merge": "pnpm --dir tools/agentic-control start pr merge",
    "a:clean": "pnpm --dir tools/agentic-control start cleanup worktree",
    "a:pm": "pnpm --dir tools/agentic-control start pm seed-issues",
    "a:pm-next": "pnpm --dir tools/agentic-control start pm next-phase",
    "a:doctor": "pnpm --dir tools/agentic-control start doctor --quick",
    "agentic:dist": "node tools/agentic-control/dist/cli.js",
    "agentic:build": "pnpm --dir tools/agentic-control build",
    "agentic:test": "pnpm --dir tools/agentic-control test"
  }
}
