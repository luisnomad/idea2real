{
  "name": "idea2real",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "pnpm --filter @idea2real/web dev",
    "dev:api": "pnpm --filter @idea2real/api dev",
    "test": "pnpm -r test",
    "test:web": "pnpm --filter @idea2real/web test",
    "test:api": "pnpm --filter @idea2real/api test",
    "test:contracts": "pnpm --filter @idea2real/contracts test",
    "build:web": "pnpm --filter @idea2real/web build",
    "typecheck:api": "pnpm --filter @idea2real/api typecheck",
    "typecheck:contracts": "pnpm --filter @idea2real/contracts typecheck"
  }
}
